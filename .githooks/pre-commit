#!/usr/bin/env bash
# Before every commit:
#   1. Compile changed song variants to PDF via typst
#   2. Sync song list in index.html and README.md

set -e
ROOT="$(git rev-parse --show-toplevel)"

# ── 0. Show what is staged ────────────────────────────────────────────────────
echo "Staged changes:"
git diff --cached --name-status | sed 's/^/  /'
echo ""

# ── 1. Compile PDFs for staged or modified lang .typ files ───────────────────
if ! command -v typst &>/dev/null; then
  echo "warning: typst not found, skipping PDF compilation" >&2
else
  # Lang files: songs/SongName/lang.typ (not song.typ)
  CHANGED=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^songs/[^/]+/[^/]+\.typ$' \
    | grep -v '/song\.typ$' || true)

  # Shared files — recompile everything
  SHARED=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^(template|settings)\.typ$|^songs/[^/]+/song\.typ$' || true)

  if [ -n "$SHARED" ]; then
    echo "  shared file changed — recompiling all variants"
    for lang_file in "$ROOT"/songs/*/*.typ; do
      [[ "$(basename "$lang_file")" == "song.typ" ]] && continue
      folder=$(basename "$(dirname "$lang_file")")
      lang=$(basename "$lang_file" .typ)
      out="$ROOT/pdf/$folder/$lang.pdf"
      mkdir -p "$(dirname "$out")"
      echo "  compile: $folder / $lang"
      typst compile --root "$ROOT" "$lang_file" "$out"
    done
  elif [ -n "$CHANGED" ]; then
    while IFS= read -r rel; do
      lang_file="$ROOT/$rel"
      folder=$(basename "$(dirname "$lang_file")")
      lang=$(basename "$lang_file" .typ)
      out="$ROOT/pdf/$folder/$lang.pdf"
      mkdir -p "$(dirname "$out")"
      echo "  compile: $folder / $lang"
      typst compile --root "$ROOT" "$lang_file" "$out"
    done <<< "$CHANGED"
  fi

  git add "$ROOT/pdf/"
fi

# ── 2. Sync index.html and README.md ─────────────────────────────────────────
python "$ROOT/update_songs.py" || exit 1
git add "$ROOT/index.html" "$ROOT/README.md"
